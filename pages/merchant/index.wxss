.merchant-shell {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  background:
    radial-gradient(circle at top left, rgba(52, 104, 95, 0.28), transparent 28%),
    linear-gradient(180deg, #eef4ef, #dbe7dd);
}

.merchant-banner {
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #1c4038, #0f2b26);
  color: #f6efe6;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
}

.merchant-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.back-btn {
  align-self: flex-start;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
}

.tab-row {
  display: flex;
  gap: 14rpx;
}

.tab-chip {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #44645c;
  font-size: 24rpx;
}

.tab-chip.active {
  background: #1c4038;
  color: #f6efe6;
}

.merchant-pane {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.metric-card,
.summary-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 48rpx rgba(18, 61, 53, 0.08);
}

.metric-label,
.summary-label {
  display: block;
  color: #58726e;
  font-size: 22rpx;
}

.metric-value,
.summary-value {
  display: block;
  margin-top: 14rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #13352f;
}

.merchant-section {
  padding: 24rpx;
}

.hot-list,
.merchant-orders,
.menu-admin-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.hot-item,
.merchant-order-card,
.menu-admin-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f6fbf7;
}

.hot-item {
  display: flex;
  justify-content: space-between;
}

.merchant-order-top,
.menu-admin-head,
.menu-admin-actions {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.dark {
  background: #d7ebe3;
  color: #1a4a40;
}

.merchant-items {
  display: block;
  margin-top: 10rpx;
  color: #4c665f;
  font-size: 24rpx;
}

.merchant-btn,
.menu-edit-btn,
.editor-image-btn,
.editor-cancel,
.editor-save {
  margin-top: 18rpx;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.merchant-btn,
.menu-edit-btn,
.editor-save {
  background: #1c4038;
  color: #f6efe6;
}

.empty-inline {
  margin-top: 16rpx;
  color: #657f76;
  font-size: 24rpx;
}

.menu-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.menu-search {
  margin-top: 18rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #eef5f0;
  color: #4f7067;
  font-size: 24rpx;
}

.filter-chip.active {
  background: #1c4038;
  color: #f6efe6;
}

.menu-admin-card {
  display: flex;
  gap: 18rpx;
}

.menu-admin-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.menu-admin-body {
  flex: 1;
}

.menu-admin-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.menu-admin-meta,
.menu-admin-desc {
  display: block;
  margin-top: 10rpx;
  color: #58726e;
  font-size: 24rpx;
  line-height: 1.5;
}

.menu-status {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  height: fit-content;
}

.menu-status.enabled {
  background: #dcefe5;
  color: #1c5d4a;
}

.menu-status.disabled {
  background: #efe1d8;
  color: #955b39;
}

.menu-admin-actions {
  align-items: center;
  margin-top: 16rpx;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 31, 27, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 99;
}

.editor-sheet {
  width: 100%;
  padding: 28rpx;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.editor-image {
  width: 100%;
  height: 280rpx;
  border-radius: 24rpx;
  margin-top: 22rpx;
}

.editor-image-btn {
  margin-top: 16rpx;
  background: #edf4f0;
  color: #1d5b4c;
}

.editor-field,
.editor-switch {
  margin-top: 20rpx;
}

.editor-label {
  display: block;
  margin-bottom: 12rpx;
  color: #49665d;
  font-size: 24rpx;
}

.editor-input,
.editor-textarea {
  width: 100%;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f5faf6;
  font-size: 26rpx;
}

.editor-textarea {
  min-height: 160rpx;
}

.editor-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.editor-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 26rpx;
}

.editor-cancel {
  background: #eef4f0;
  color: #48675e;
}
